# Frontend (Vite)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
# Mandator (label) this public shop serves — scopes every catalogue query
VITE_MANDATOR_ID=your-mandator-uuid

# Supabase Edge Functions (set via `supabase secrets set`)
# SUPABASE_URL and SUPABASE_SERVICE_ROLE_KEY are provided automatically
RESEND_API_KEY=re_your_key_here
RESEND_FROM_EMAIL=tickets@yourdomain.com
SITE_URL=https://yourdomain.com
# Signing secret of the webshop's OWN Stripe webhook endpoint (distinct from the
# ticket webhook — Stripe issues a unique secret per registered endpoint).
WEBSHOP_STRIPE_WEBHOOK_SECRET=whsec_your_webshop_endpoint_secret
